er/react-practice/sb-frontend/src/components/PetDisplay/PetDisplay.js",["209"],[],"/Users/ccho/Developer/react-practice/sb-frontend/src/components/PetDisplay/PetSprite.js",[],[],"/Users/ccho/Developer/react-practice/sb-frontend/src/components/PetDisplay/ProgressB.js",["210"],[],"/Users/ccho/Developer/react-practice/sb-frontend/src/components/PetDisplay/PetDesc.js",[],[],"/Users/ccho/Developer/react-practice/sb-frontend/src/mockData/info.js",["211","212"],[],"/Users/ccho/Developer/react-practice/sb-frontend/src/components/PageDisplay/TaskItem.js",[],[],"/Users/ccho/Developer/react-practice/sb-frontend/src/components/PageDisplay/CreateTaskForm.js",[],[],"/Users/ccho/Developer/CIS_4398/project-virtual-pet/pocs-capstone/frontend/src/index.js",[],[],[],"/Users/ccho/Developer/CIS_4398/project-virtual-pet/pocs-capstone/frontend/src/App.js",["213"],[],"import Header from './components/Header.js'\nimport Main from './components/Main.js'\nimport Footer from './components/Footer.js'\nimport Stack from 'react-bootstrap/Stack';\nimport { useState, useEffect } from 'react'\n\nimport user from './services/user.js'\n\nimport './App.css'\n\nconst App = () => {\n\n  const [userInfo, setUserInfo] = useState({})\n\n  const fetchData = () => {\n    // user\n    //   .getUserInfo(\"ccho\")\n    //   .then(r => {\n    //     setUserInfo(r)\n    //   })\n    setUserInfo(user.getUserInfo(\"ccho\"))\n  }\n\n  useEffect(fetchData, [])\n  console.log(\"Loading fetch data \", userInfo, \"data fetched \")\n\n\n  return (\n    <div className=\"fill-page\">\n      <Header title=\"My Study Buddy\"/>\n      <Main userInfo={userInfo}/>\n      <Footer userInfo={userInfo}/>\n\n    </div>\n\n    // <Stack gap={0}>\n    //   <div>\n    //   <Header title=\"My Study Buddy\"/>\n    //   </div>\n    //   <div>\n    //   <Main userInfo={userInfo}/>\n    //   </div>\n    //   <div>\n    //   <Footer userInfo={userInfo}/>\n    //   </div>\n    // </Stack>\n\n\n  )\n}\nexport default App\n",[],"/Users/ccho/Developer/CIS_4398/project-virtual-pet/pocs-capstone/frontend/src/reportWebVitals.js",[],[],"/Users/ccho/Developer/CIS_4398/project-virtual-pet/pocs-capstone/frontend/src/components/Main.js",[],[],"/Users/ccho/Developer/CIS_4398/project-virtual-pet/pocs-capstone/frontend/src/components/Header.js",[],[],"/Users/ccho/Developer/CIS_4398/project-virtual-pet/pocs-capstone/frontend/src/components/Footer.js",[],[],"/Users/ccho/Developer/CIS_4398/project-virtual-pet/pocs-capstone/frontend/src/components/PageDisplay/PageDisplay.js",["214","215","216","217","218"],[],"import \"./PageDisplay.css\"\n\nimport Tab from 'react-bootstrap/Tab';\nimport Tabs from 'react-bootstrap/Tabs';\n\nimport { useState, useEffect } from 'react'\nimport TaskPage from \"./TaskPage\";\nimport CalendarPage from \"./CalendarPage\"\nimport Button from 'react-bootstrap/Button';\nimport Card from 'react-bootstrap/Card';\nimport Nav from 'react-bootstrap/Nav';\n\nimport tasks from '../../services/tasks'\n\n\nconst PageDisplay = ({ avatarInfo, setAvatarInfo, inventory, setInventory }) => {\n    const [taskList, setTaskList] = useState([])\n\n    const fetchData = () => {\n        // tasks\n        //     .getTasks(\"USERNAME\")\n        //     .then(r => {setTaskList(r)})\n        setTaskList(tasks.getTasks())\n    }\n\n    // useEffect(fetchData, [])\n    // console.log(\"Loading fetch data tasks\", taskList, \"data fetched \")\n\n\n    return (\n        <div className=\"page-display\">\n            <Tabs\n                defaultActiveKey=\"tasks\"\n                id=\"justify-tab-example\"\n                className=\"mb-3\"\n                justify\n            >\n\n\n                <Tab eventKey=\"tasks\" title=\"Tasks\">\n\n                    <TaskPage {...{ taskList, setAvatarInfo, setInventory, setTaskList }} />\n\n                    \n                </Tab>\n                <Tab eventKey=\"calendar\" title=\"Calendar\">\n                    <CalendarPage />\n                </Tab>\n                <Tab eventKey=\"inventory\" title=\"Inventory\">\n                    {/* <Sonnet /> */}\n                </Tab>\n                <Tab eventKey=\"progress\" title=\"Progress\">\n                    {/* <Sonnet /> */}\n                </Tab>\n            </Tabs>\n        </div>\n    )\n}\n\nexport default PageDisplay","/Users/ccho/Developer/CIS_4398/project-virtual-pet/pocs-capstone/frontend/src/components/PetDisplay/PetDisplay.js",["219"],[],"/Users/ccho/Developer/CIS_4398/project-virtual-pet/pocs-capstone/frontend/src/services/inventory.js",[],[],"/Users/ccho/Developer/CIS_4398/project-virtual-pet/pocs-capstone/frontend/src/services/avatarInfo.js",[],[],"/Users/ccho/Developer/CIS_4398/project-virtual-pet/pocs-capstone/frontend/src/components/PetDisplay/PetDesc.js",[],[],"/Users/ccho/Developer/CIS_4398/project-virtual-pet/pocs-capstone/frontend/src/components/PetDisplay/ProgressB.js",["220"],[],"/Users/ccho/Developer/CIS_4398/project-virtual-pet/pocs-capstone/frontend/src/components/PetDisplay/PetSprite.js",["221","222","223"],[],"/Users/ccho/Developer/CIS_4398/project-virtual-pet/pocs-capstone/frontend/src/components/PageDisplay/TaskPage.js",["224","225","226"],[],"import './PageDisplay.css'\nimport TabContent from 'react-bootstrap/TabContent'\nimport Card from 'react-bootstrap/Card';\n\n\n\nimport Stack from 'react-bootstrap/Stack';\nimport NavDropdown from 'react-bootstrap/NavDropdown';\nimport Button from 'react-bootstrap/Button';\nimport Modal from 'react-bootstrap/Modal';\nimport CreateTaskForm from './CreateTaskForm';\nimport TaskList from './TaskList'\nimport {useState} from 'react';\n\nconst TaskPage = ({taskList, setAvatarInfo, setInventory, setTaskList}) => {\n    const [showCreateTask, setShowCreateTask] = useState(false);\n    const handleClose = () => setShowCreateTask(false);\n    const handleShow = () => setShowCreateTask(true);\n    console.log(\"??\", taskList)\n    return (\n        <div className=\"mini-page\">\n            <Card className='tasklist-position'>\n                <Card.Header>\n                <Stack direction=\"horizontal\" gap={3}>\n                    <div className='to-do-header'>\n                    TO-DO:\n                    </div>\n                    <div className=\"ms-auto\">\n                    <Button variant=\"primary\" onClick={handleShow}>+ Create Task</Button>\n                    </div>\n                </Stack>\n                </Card.Header>\n\n                <TaskList taskList={taskList}/>\n                \n            </Card>\n\n            <CreateTaskForm show={showCreateTask} hide={handleClose}/>\n        </div>\n    )\n}\n\nexport default TaskPage","/Users/ccho/Developer/CIS_4398/project-virtual-pet/pocs-capstone/frontend/src/components/PageDisplay/CreateTaskForm.js",[],[],"/Users/ccho/Developer/CIS_4398/project-virtual-pet/pocs-capstone/frontend/src/components/PageDisplay/TaskItem.js",["227","228","229","230","231","232","233"],[],"/Users/ccho/Developer/CIS_4398/project-virtual-pet/pocs-capstone/frontend/src/mockData/info.js",["234"],[],"/Users/ccho/Developer/CIS_4398/project-virtual-pet/pocs-capstone/frontend/src/services/user.js",[],[],"/Users/ccho/Developer/CIS_4398/project-virtual-pet/pocs-capstone/frontend/src/services/tasks.js",["235"],[],"/Users/ccho/Developer/CIS_4398/project-virtual-pet/pocs-capstone/frontend/src/components/PageDisplay/CalendarPage.js",[],[],"/Users/ccho/Developer/CIS_4398/project-virtual-pet/pocs-capstone/frontend/src/components/PageDisplay/TaskList.js",["236"],[],{"ruleId":"237","severity":1,"message":"238","line":10,"column":12,"nodeType":"239","messageId":"240","endLine":10,"endColumn":22},{"ruleId":"237","severity":1,"message":"241","line":11,"column":12,"nodeType":"239","messageId":"240","endLine":11,"endColumn":21},{"ruleId":"237","severity":1,"message":"242","line":13,"column":11,"nodeType":"239","messageId":"240","endLine":13,"endColumn":20},{"ruleId":"237","severity":1,"message":"243","line":2,"column":8,"nodeType":"239","messa